# PostgreSQL credentials (used by both postgres container and backend)
POSTGRES_USER=mremotify
POSTGRES_PASSWORD=mremotify
POSTGRES_DB=mremotify
POSTGRES_URL=postgresql://mremotify:mremotify@localhost:5432/mremotify

# AES-256 encryption key for passwords (must be exactly 32 characters)
# Generate with: openssl rand -base64 24
ENCRYPTION_KEY=change-me-to-a-random-32char-key!

# JWT signing secret (use a strong random value)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-jwt-secret

# Default admin credentials (used during first-time seeding only)
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# RDP daemon WebSocket URL
RDPD_URL=ws://rdpd:7777

# Backend port
PORT=3000

# ─────────────────────────────────────────
# TLS / HTTPS Configuration
# ─────────────────────────────────────────

# Set to true to enable HTTPS on nginx (TLS termination at the frontend)
TLS_ENABLED=false

# Your hostname or IP (used for nginx server_name and HTTP→HTTPS redirect)
APP_HOSTNAME=localhost

# HTTP and HTTPS ports (change if 80/443 are taken)
HTTP_PORT=80
HTTPS_PORT=443

# ── Option A: Certificate files (recommended for local installs) ──
# Place your cert and key in a local directory and set CERTS_DIR
# Example: CERTS_DIR=/home/felix/mremotify-certs
CERTS_DIR=
TLS_CERT_FILE=/certs/tls.crt
TLS_KEY_FILE=/certs/tls.key

# ── Option B: Base64 inline PEM (useful for CI/CD or env-only deploys) ──
# Generate with: cat tls.crt | base64 -w0
TLS_CERT_B64=
TLS_KEY_B64=
